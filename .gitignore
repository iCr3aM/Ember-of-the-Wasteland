# Compiled script files. These are important for saving, and so should
# be preserved by developer and build systems after the game has been released.
# 忽略 Ren'Py 编译出的二进制缓存文件，这些文件在游戏运行时会被重新生成。
/game/**/*.rpyc
/game/**/*.rpymc

# Files Ren'Py can generate.
/game/**/*.bak
/game/**/*.new
/game/**/*.old

# 忽略 Ren'Py 自动生成的保存数据和日志
/errors.txt
/files.txt
/image_cache.txt
/log.txt
/save_dump.txt
/traceback.txt
/game/saves
/game/cache

# Launcher-generated files.
/dialogue.tab
/dialogue.txt
/strings.json

# 忽略操作系统和浏览器的临时文件
.DS_Store
Thumbs.db

# 忽略构建导出的游戏成品目录
/build/

# 忽略
/.github/
bundle.keystore
android.json
android.keystore
/.vscode/
